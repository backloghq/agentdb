{
  "name": "@backloghq/agentdb",
  "version": "0.1.0",
  "description": "AI-first embedded database for LLM agents. Library-first architecture with framework-agnostic tool definitions and MCP adapter.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "bin": {
    "agentdb": "./dist/mcp/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ tests/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "agent",
    "database",
    "embedded",
    "llm",
    "mcp",
    "document-store",
    "ai"
  ],
  "author": "mbocevski",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@backloghq/opslog": "^0.5.0",
    "@backloghq/opslog-s3": "^0.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "jose": "^6.2.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
